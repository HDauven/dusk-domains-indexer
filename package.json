{
  "name": "@hdauven/dusk-domains-indexer",
  "private": true,
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "description": "Standalone event indexer and read API for Dusk Domains.",
  "files": [
    "server",
    "scripts",
    "deploy",
    "docs",
    "Dockerfile",
    ".dockerignore",
    "README.md",
    "LICENSE",
    "!server/**/*.test.mjs",
    "!server/**/*test-helpers.mjs",
    "!server/**/*event-fixtures.mjs",
    "!scripts/**/*.test.mjs",
    "!scripts/test-fixtures"
  ],
  "scripts": {
    "start": "node server/local-indexer.mjs",
    "test": "vitest run",
    "check": "vitest run",
    "smoke": "node scripts/local-indexer-smoke.mjs",
    "backfill:check": "node scripts/local-indexer-backfill-check.mjs",
    "health": "node scripts/indexer-health-probe.mjs",
    "monitor": "node scripts/indexer-monitor.mjs",
    "backup": "node scripts/indexer-backup.mjs",
    "disk": "node scripts/indexer-disk-budget.mjs",
    "production:check": "node scripts/production-indexer-check.mjs"
  },
  "dependencies": {
    "@dusk/w3sper": "npm:@jsr/dusk__w3sper@^1.6.0",
    "@duskdomains/sdk": "npm:@jsr/duskdomains__sdk@^0.1.6",
    "@noble/hashes": "^2.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=24"
  }
}
