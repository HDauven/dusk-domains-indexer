# Dusk Domains indexer runtime
DUSK_DOMAINS_INDEXER_HOST=127.0.0.1
DUSK_DOMAINS_INDEXER_PORT=8787
DUSK_DOMAINS_INDEXER_CORS_ORIGIN=https://dusk.domains
DUSK_DOMAINS_INDEXER_HEALTH_URL=http://127.0.0.1:8787/health

# Persistent read-model inputs and state
DUSK_DOMAINS_INDEXER_DATA_DIR=/var/lib/dusk-domains
DUSK_DOMAINS_INDEXER_EVENT_LOG=/var/lib/dusk-domains/events.jsonl
DUSK_DOMAINS_INDEXER_SQLITE=/var/lib/dusk-domains/indexer.sqlite
DUSK_DOMAINS_INDEXER_CURSOR=/var/lib/dusk-domains/cursor.json
DUSK_DOMAINS_INDEXER_CHECKPOINT=/var/lib/dusk-domains/checkpoint.json

# Health and monitoring policy
DUSK_DOMAINS_INDEXER_MAX_LAG_BLOCKS=12
DUSK_DOMAINS_INDEXER_MAX_SOURCE_AGE_MINUTES=10
DUSK_DOMAINS_INDEXER_ALERT_WEBHOOK_URL=

# Backup policy
DUSK_DOMAINS_INDEXER_BACKUP_DIR=/var/backups/dusk-domains
DUSK_DOMAINS_INDEXER_BACKUP_RESTORE_DIR=/tmp/dusk-domains-indexer-restore

# Deployment evidence used by production checks
DUSK_DOMAINS_DEPLOYMENT_ENV_FILE=/var/lib/dusk-domains/.env.testnet.local
DUSK_DOMAINS_DEPLOYMENT_PROOF=/var/lib/dusk-domains/deployment-proof.json
DUSK_DOMAINS_ARCHIVE_SNAPSHOT=/var/lib/dusk-domains/archive-snapshot.marker.json
DUSK_DOMAINS_DEPLOYMENT_START_HEIGHT=
DUSK_DOMAINS_ARCHIVE_SNAPSHOT_HEIGHT=
